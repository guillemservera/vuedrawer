{
  "name": "vuedrawer",
  "version": "0.1.0",
  "description": "A headless, unstyled and behaviorally opinionated drawer primitive for Vue 3 with gestures, snap points, nested drawers and zero runtime dependencies.",
  "type": "module",
  "license": "MIT",
  "author": "Guillem Servera",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guillemservera/vuedrawer.git"
  },
  "bugs": {
    "url": "https://github.com/guillemservera/vuedrawer/issues"
  },
  "homepage": "https://github.com/guillemservera/vuedrawer#readme",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "peerDependencies": {
    "vue": "^3.4.0 || ^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.8.3",
    "uqr": "^0.1.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.1.3",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.10"
  },
  "keywords": [
    "vue",
    "vue3",
    "drawer",
    "bottom-sheet",
    "sheet",
    "modal",
    "headless",
    "unstyled",
    "gestures",
    "snap-points",
    "nested-drawers"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:playground": "pnpm --filter @vuedrawer/playground dev",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:dry": "npm pack --dry-run"
  }
}
